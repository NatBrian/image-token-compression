# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Environment / secrets
.env
*.env

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Runtime logs / event data
*.log
.imgctx/

# Session scratch (created by tooling, not part of the project)
.remember/

# Benchmark outputs
bench/last_result.json
bench/baseline_result.json

# Benchmark raw per-item artifacts (kept on disk for inspection, NOT committed).
# For every benchmark the summary REPORT.md + aggregated results.json ARE tracked;
# the heavy/transient run data (repo checkouts, per-item streams, patches, proxy
# event logs, run-local backups) is ignored.

# HotpotQA (OpenCode/mimo path)
bench/hotpot_runs/off/
bench/hotpot_runs/on/
bench/hotpot_runs/*.log

# HotpotQA (Claude Code path)
bench/hotpot_claude_runs/off/
bench/hotpot_claude_runs/on/
bench/hotpot_claude_runs/_sonnet_streams/
bench/hotpot_claude_runs/*.log
bench/hotpot_claude_runs/proxy_*events*.jsonl
bench/hotpot_claude_runs/results_*.json
# but DO track the IMGCTX_TOOLS=0 rerun's aggregate (backs the deep-dive Section 13
# "measured flip" numbers); heavy per-item streams under off_tools0/on_tools0 stay out.
!bench/hotpot_claude_runs/results_tools0.json
bench/hotpot_claude_runs/off_tools0/
bench/hotpot_claude_runs/on_tools0/

# Long-doc single-shot (Claude Code path). Track LONGDOC_REPORT.md + results_*.json
# + the cached data_*.json question sets; ignore heavy per-item streams/logs.
bench/longdoc_runs/off/
bench/longdoc_runs/on/
bench/longdoc_runs/*.log
bench/longdoc_runs/proxy_*events*.jsonl
bench/longdoc_runs/results.json
bench/longdoc_runs/data_*.json

# Long-doc single-shot (OpenCode/mimo path). Track results_*.json; ignore heavy streams.
bench/longdoc_opencode_runs/off/
bench/longdoc_opencode_runs/on/
bench/longdoc_opencode_runs/*.log

# SWE-bench (OpenCode/mimo path). Track results.json + instances.json; ignore repos/streams.
bench/swebench_opencode_runs/_repos_cache/
bench/swebench_opencode_runs/off/
bench/swebench_opencode_runs/on/
bench/swebench_opencode_runs/*.log

# SWE-bench (Claude Code path)
bench/swebench_runs/_repos_cache/
bench/swebench_runs/off/
bench/swebench_runs/on/
bench/swebench_runs/*.log
bench/swebench_runs/proxy_*events*.jsonl
bench/swebench_runs/results_*.json
